triple.tanglegram(tree1, tree2, tree3, column = "category", t2_pad = 0.5, t3_pad = 0.5)
# 1. Simple Tanglegram (Filters for "Group 1")
simple.tanglegram(tree1, tree2, column = "category", value = "Group 1")
