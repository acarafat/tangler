library(ggplot2)
library(ggtree)
library(dplyr)
library(tangler)
devtools::document()
devtools::check()
devtools::install_github("acarafat/tangler@v0.3.0")
library(tangler)
exists("triple.tanglegram")
?triple.tanglegram
devtools::install_github("acarafat/tangler@v0.3.0", force = TRUE)
library(ggplot2)
library(ggtree)
library(dplyr)
library(tangler)
library(ape)
# Create 3 simple trees
set.seed(42)
t1 <- rtree(10)
t2 <- rtree(10)
t3 <- rtree(10)
t1$tip.label <- paste0("t", 1:10)
t2$tip.label <- paste0("t", 1:10)
t3$tip.label <- paste0("t", 1:10)
# Create metadata
meta <- data.frame(
label = paste0("t", 1:10),
category = sample(c("Group 1", "Group 2", "Group 3"), 10, replace = TRUE)
)
# Convert to ggtree objects and join metadata
tree1 <- ggtree(t1) %<+% meta
tree2 <- ggtree(t2) %<+% meta
tree3 <- ggtree(t3) %<+% meta
# 1. Simple Tanglegram (Filters for "Group 1")
simple.tanglegram(tree1, tree2, column = category, value = "Group 1")
# 2. Common Tanglegram
common.tanglegram(tree1, tree2, column = "category", t2_pad = 0.5)
